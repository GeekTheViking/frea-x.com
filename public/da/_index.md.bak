---
---

<div class="welcome-section">
    <h1>Velkommen, Jan</h1>
    <p>Mandag, 16. marts 2026</p>
</div>

<div class="stats-grid">
    <a href="/da/mails/indbakke" class="stat-card">
        <h3>ULFESTE BESKEDER</h3>
        <div class="stat-number">5</div>
        <div class="stat-sub">2 nye siden i går</div>
    </a>
    <a href="/da/kalender" class="stat-card">
        <h3>DAGENS AFTALER</h3>
        <div class="stat-number">3</div>
        <div class="stat-sub">Næste: Demo kl. 14:00</div>
    </a>
    <a href="/da/kontakter" class="stat-card">
        <h3>KONTAKTER</h3>
        <div class="stat-number">142</div>
        <div class="stat-sub">3 nye denne uge</div>
    </a>
    <a href="/da/filer" class="stat-card">
        <h3>LAGERPLADS</h3>
        <div class="stat-number">4.2 GB</div>
        <div class="stat-sub">af 25 GB brugt</div>
    </a>
</div>

<div class="dashboard-grid">
    <div class="dashboard-column">
        <div class="dashboard-widget">
            <h2>Seneste mails</h2>
            <ul class="mail-list">
                <li><strong>EU Digital Services</strong><br>Velkommen til Postbox.eu</li>
                <li><strong>Datatilsynet</strong><br>GDPR opdatering — Marts 2026</li>
                <li><strong>Anders Nielsen</strong><br>Meld dig til digital serveren</li>
            </ul>
            <a href="/da/mails/indbakke" class="widget-link">Se alle mails →</a>
        </div>
    </div>
    <div class="dashboard-column">
        <div class="dashboard-widget">
            <h2>I dag — 16. marts</h2>
            <ul class="event-list">
                <li><span class="event-time">09:00</span> Morgenmøde</li>
                <li><span class="event-time">14:00</span> Demo præsentation</li>
            </ul>
            <a href="/da/kalender" class="widget-link">Se kalender →</a>
        </div>
        <div class="dashboard-widget">
            <h2>Dine Filer</h2>
            <ul class="file-list">
                <li>📄 Præsentation.pdf <span class="file-size">2.1 MB</span></li>
            </ul>
            <a href="/da/filer" class="widget-link">Åbn Dine Filer →</a>
        </div>
    </div>
</div>
